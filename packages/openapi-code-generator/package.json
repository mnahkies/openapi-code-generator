{
  "name": "@nahkies/openapi-code-generator",
  "version": "0.26.0",
  "type": "module",
  "description": "Typescript client SDK and server stub generator for OpenAPI 3 specifications",
  "license": "MIT",
  "author": {
    "name": "Michael Nahkies",
    "email": "support@nahkies.co.nz"
  },
  "homepage": "https://openapi-code-generator.nahkies.co.nz/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnahkies/openapi-code-generator.git",
    "directory": "packages/openapi-code-generator"
  },
  "bugs": {
    "url": "https://github.com/mnahkies/openapi-code-generator/issues"
  },
  "bin": {
    "openapi-code-generator": "./bin/cli.mjs"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/esm/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./cli": {
      "import": {
        "types": "./dist/esm/cli.d.mts",
        "default": "./dist/esm/cli.mjs"
      },
      "require": {
        "types": "./dist/cjs/cli.d.cts",
        "default": "./dist/cjs/cli.cjs"
      }
    },
    "./web": {
      "import": {
        "types": "./dist/esm/web.d.mts",
        "default": "./dist/esm/web.mjs"
      },
      "require": {
        "types": "./dist/cjs/web.d.cts",
        "default": "./dist/cjs/web.cjs"
      }
    }
  },
  "scripts": {
    "clean": "rm -rf ./dist && rm -f tsconfig.tsbuildinfo",
    "build": "tsc -p ./tsconfig.json",
    "bundle": "tsdown",
    "test": "vitest run"
  },
  "devDependencies": {
    "@azure-tools/typespec-autorest": "catalog:",
    "@azure-tools/typespec-azure-core": "catalog:",
    "@azure-tools/typespec-azure-resource-manager": "catalog:",
    "@azure-tools/typespec-client-generator-core": "catalog:",
    "@nahkies/typescript-common-runtime": "workspace:^",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@typespec/compiler": "^1.12.0",
    "@typespec/events": "0.83.0",
    "@typespec/http": "^1.12.0",
    "@typespec/openapi": "^1.12.0",
    "@typespec/openapi3": "^1.12.0",
    "@typespec/rest": "0.83.0",
    "@typespec/sse": "0.83.0",
    "@typespec/streams": "0.83.0",
    "@typespec/versioning": "0.83.0",
    "@typespec/xml": "0.83.0",
    "joi": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@biomejs/biome": "2.5.0",
    "@biomejs/js-api": "4.0.0",
    "@biomejs/wasm-nodejs": "2.4.15",
    "@commander-js/extra-typings": "catalog:",
    "ajv": "^8.20.0",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^3.0.1",
    "commander": "catalog:",
    "js-yaml": "catalog:",
    "json5": "^2.2.3",
    "lodash": "^4.18.1",
    "tslib": "^2.8.1",
    "typescript": "catalog:",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.12.0",
    "@typespec/events": "^0.82.0",
    "@typespec/http": "^1.12.0",
    "@typespec/openapi": "^1.12.0",
    "@typespec/openapi3": "^1.12.0",
    "@typespec/rest": "^0.82.0",
    "@typespec/sse": "^0.82.0",
    "@typespec/streams": "^0.82.0",
    "@typespec/versioning": "^0.82.0",
    "@typespec/xml": "^0.82.0",
    "prettier": "catalog:"
  },
  "peerDependenciesMeta": {
    "@typespec/compiler": {
      "optional": true
    },
    "@typespec/events": {
      "optional": true
    },
    "@typespec/http": {
      "optional": true
    },
    "@typespec/openapi": {
      "optional": true
    },
    "@typespec/openapi3": {
      "optional": true
    },
    "@typespec/rest": {
      "optional": true
    },
    "@typespec/sse": {
      "optional": true
    },
    "@typespec/streams": {
      "optional": true
    },
    "@typespec/versioning": {
      "optional": true
    },
    "@typespec/xml": {
      "optional": true
    },
    "prettier": {
      "optional": true
    }
  },
  "files": [
    "src",
    "bin",
    "dist",
    "README.md",
    "CHANGELOG.md",
    "package.json",
    "tsconfig.json"
  ],
  "keywords": [
    "openapi",
    "openapi3",
    "typespec",
    "swagger",
    "typescript",
    "zod",
    "api",
    "sdk",
    "generator",
    "codegen",
    "koa",
    "express",
    "fetch",
    "axios",
    "angular"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
