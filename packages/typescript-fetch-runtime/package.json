{
  "name": "@nahkies/typescript-fetch-runtime",
  "version": "0.26.0",
  "type": "module",
  "description": "Runtime package for code generated by @nahkies/openapi-code-generator using the typescript-fetch template",
  "license": "MIT",
  "author": {
    "name": "Michael Nahkies",
    "email": "support@nahkies.co.nz"
  },
  "homepage": "https://openapi-code-generator.nahkies.co.nz/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnahkies/openapi-code-generator.git",
    "directory": "packages/typescript-fetch-runtime"
  },
  "bugs": {
    "url": "https://github.com/mnahkies/openapi-code-generator/issues"
  },
  "exports": {
    "./main": {
      "import": {
        "types": "./dist/esm/main.d.mts",
        "default": "./dist/esm/main.mjs"
      },
      "require": {
        "types": "./dist/cjs/main.d.cts",
        "default": "./dist/cjs/main.cjs"
      }
    },
    "./joi": {
      "import": {
        "types": "./dist/esm/joi.d.mts",
        "default": "./dist/esm/joi.mjs"
      },
      "require": {
        "types": "./dist/cjs/joi.d.cts",
        "default": "./dist/cjs/joi.cjs"
      }
    },
    "./zod-v3": {
      "import": {
        "types": "./dist/esm/zod-v3.d.mts",
        "default": "./dist/esm/zod-v3.mjs"
      },
      "require": {
        "types": "./dist/cjs/zod-v3.d.cts",
        "default": "./dist/cjs/zod-v3.cjs"
      }
    },
    "./zod-v4": {
      "import": {
        "types": "./dist/esm/zod-v4.d.mts",
        "default": "./dist/esm/zod-v4.mjs"
      },
      "require": {
        "types": "./dist/cjs/zod-v4.d.cts",
        "default": "./dist/cjs/zod-v4.cjs"
      }
    }
  },
  "scripts": {
    "clean": "rm -rf ./dist && rm -f tsconfig.tsbuildinfo",
    "build": "tsc -p ./tsconfig.json",
    "bundle": "tsdown",
    "test": "vitest run"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "joi": "^17.13.3 || ^18.0.1",
    "zod": "^3.25.74 || ^4.1.12"
  },
  "peerDependenciesMeta": {
    "joi": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nahkies/typescript-common-runtime": "workspace:^",
    "joi": "^18.2.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.11",
    "zod": "^4.3.6"
  },
  "files": [
    "src",
    "dist/cjs",
    "dist/esm",
    "README.md",
    "CHANGELOG.md",
    "package.json",
    "tsconfig.json"
  ],
  "keywords": [
    "@nahkies/openapi-code-generator",
    "runtime",
    "typescript-fetch",
    "fetch"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
