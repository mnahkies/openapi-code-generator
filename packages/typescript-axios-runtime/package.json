{
  "name": "@nahkies/typescript-axios-runtime",
  "version": "0.22.0",
  "type": "module",
  "description": "Runtime package for code generated by @nahkies/openapi-code-generator using the typescript-axios template",
  "license": "MIT",
  "author": {
    "name": "Michael Nahkies",
    "email": "support@nahkies.co.nz"
  },
  "homepage": "https://openapi-code-generator.nahkies.co.nz/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnahkies/openapi-code-generator.git",
    "directory": "packages/typescript-axios-runtime"
  },
  "bugs": {
    "url": "https://github.com/mnahkies/openapi-code-generator/issues"
  },
  "exports": {
    "./main": {
      "import": {
        "types": "./dist/esm/main.d.mts",
        "default": "./dist/esm/main.mjs"
      },
      "require": {
        "types": "./dist/cjs/main.d.cts",
        "default": "./dist/cjs/main.cjs"
      }
    }
  },
  "scripts": {
    "clean": "rm -rf ./dist && rm -f tsconfig.tsbuildinfo",
    "build": "tsc -p ./tsconfig.json",
    "bundle": "tsdown",
    "test": "jest"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "axios": "^1.15.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@nahkies/typescript-common-runtime": "workspace:^",
    "axios": "^1.15.2",
    "jest": "^30.3.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "files": [
    "src",
    "dist/cjs",
    "dist/esm",
    "README.md",
    "CHANGELOG.md",
    "package.json",
    "tsconfig.json"
  ],
  "keywords": [
    "@nahkies/openapi-code-generator",
    "runtime",
    "typescript-axios",
    "axios"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
